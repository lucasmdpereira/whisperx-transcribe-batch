# Copy to .env and fill in your values. .env is gitignored.

# --- Storage paths (required) ---
# Where normalized .speakers.json + .metadata.json are written.
OUTPUT_DIR=/path/to/transcripts
# Where ffmpeg-treated 16 kHz mono WAVs are stored (reused across runs).
AUDIO_BACKUP_DIR=/path/to/treated-audio
# Local cache for files downloaded from SFTP (used only by transcribe_batch).
CACHE_DIR=/path/to/raw-audios-cache

# --- GPU ---
# Physical CUDA device index. The transcription pipeline uses a single GPU.
GPU_INDEX=0

# --- Hugging Face token (required for diarization) ---
# Pick ONE of the two below. HF_TOKEN takes precedence if both are set.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_FILE=/path/to/hf_token

# --- WhisperX binary (optional) ---
# If unset, the wrapper looks for .venv/bin/whisperx and then $PATH.
# WHISPERX_BIN=/path/to/.venv/bin/whisperx

# --- SFTP source (only needed for transcribe_batch) ---
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASS=
SFTP_REMOTE_DIR=/
